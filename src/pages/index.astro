---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Welcome">
  <div class="home-container">
    <div class="intro-grid">
      <div class="intro-text-content">
        <p class="greeting">HI, I'M SURADET</p>
        <h1 class="headline">
          Pharmacist by Training,<br />Developer by Passion.
        </h1>
        <p class="description">
          ยินดีต้อนรับสู่ RxDev Man นะครับ ^^
          ผมสร้างเว็บบล็อกนี้ขึ้นมาเพื่อบันทึกสิ่งที่ได้เรียนรู้ในโลกของการเขียนโปรแกรม
          ในเว็บบล็อกนี้หลักๆก็จะเน้นไปที่บทความครับ
          อาจจะมีเครื่องมือที่ผมสร้างขึ้นเองบ้าง หรืออาจจะมีอะไรเพิ่มเติมในอนาคต
          ถ้าอยากรู้ว่ามีอะไรบ้าง มาค้นหากันเลยครับ
        </p>
        <a href="/blog" class="cta-button">Explore My Notes</a>
      </div>
      <div class="profile-image-container">
        <img
          src="/images/common/profile-placeholder.jpg"
          alt="A portrait of the author"
          class="profile-image"
        />
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .home-container {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 280px);
    padding: 2rem 0;
  }

  .intro-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    align-items: center;
    gap: 4rem;
    max-width: 1100px;
  }

  .greeting {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--font-color-light);
    margin-bottom: var(--space-4);
    letter-spacing: 0.05em;
  }

  .headline {
    font-size: var(--text-xl);
    font-weight: 700;
    margin-bottom: var(--space-6);
    line-height: 1.4;
  }

  .description {
    font-size: var(--text-base);
    max-width: 600px;
    margin-bottom: var(--space-10);
  }

  .profile-image-container {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .profile-image {
    width: 280px;
    height: 280px;
    border-radius: var(--radius-full);
    object-fit: cover;
    border: 5px solid var(--card-bg-color);
    box-shadow: 0 10px 30px var(--shadow-hover-color);
  }

  @media (max-width: 1024px) {
    .intro-grid {
      grid-template-columns: 1fr;
      text-align: center;
      gap: var(--space-12);
    }
    .intro-text-content {
      order: 2;
    }
    .profile-image-container {
      order: 1;
    }
    .description {
      margin-left: auto;
      margin-right: auto;
    }
    .profile-image {
      width: 220px;
      height: 220px;
    }
  }
</style>
