---
import FeatureCard from '@/components/ui/FeatureCard.astro';
import FeatureGrid from '@/components/ui/FeatureGrid.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';

const appUrl = 'http://cupsabot.rxdevman.com';
---

<BaseLayout title="Project: ระบบเบิกจ่ายยาออนไลน์">
  <div class="project-showcase">
    <header class="project-header">
      <h1>ระบบเบิกจ่ายยาออนไลน์</h1>
      <p class="subtitle">
        เว็บแอปพลิเคชันเต็มรูปแบบสำหรับเพิ่มประสิทธิภาพการจัดการและติดตามการเบิกจ่ายยาของคปสอ.สระโบสถ์
      </p>

      <div class="button-group">
        <a
          href={appUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="cta-button launch-button"
        >
          เปิดใช้งานระบบ
        </a>
      </div>
    </header>

    <div class="screenshot-container">
      <img
        src="/images/tools/cupsabot.png"
        alt="Screenshot of the medication dispensing app dashboard"
        class="main-screenshot"
      />
    </div>

    <div class="project-details">
      <h2>คุณสมบัติหลัก</h2>
      <FeatureGrid>
        <FeatureCard title="ระบบเบิกยาของรพ.สต." icon="clock">
          สร้างใบเบิกยาสำหรับ รพ.สต. ในพื้นที่คปสอ.สระโบสถ์ได้อย่างรวดเร็ว ง่าย สะดวก
        </FeatureCard>
        <FeatureCard title="ระบบบริหารจัดการยาและใบเบิก" icon="lock-closed">
          จัดการรายการยาและใบเบิกได้อย่างมีประสิทธิภาพ
        </FeatureCard>
      </FeatureGrid>

      <div class="tech-stack-section">
        <h2>Tech Stack</h2>
        <div class="stack-items">
            <span class="stack-item">Astro</span>
            <span class="stack-item">React</span>
            <span class="stack-item">Supabase</span>
            <span class="stack-item">Tailwind CSS</span>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .project-header {
    text-align: center;
    margin: var(--space-8) 0 var(--space-12);
  }
  .subtitle {
    font-size: var(--text-base);
    margin: var(--space-4) auto var(--space-8);
  }

  .button-group {
    display: flex;
    justify-content: center;
    gap: var(--space-4);
    align-items: center;
    flex-wrap: wrap;
  }

  .launch-button {
    font-size: var(--text-base);
    padding: var(--space-4) var(--space-10);
  }

  .screenshot-container {
    max-width: 1000px;
    margin: 0 auto var(--space-12);
  }
  .main-screenshot {
    border-radius: var(--radius-lg);
    border: 1px solid var(--card-border-color);
    box-shadow: 0 15px 40px var(--shadow-hover-color);
    width: 100%;
    height: auto;
  }
  .project-details {
    max-width: 900px;
    margin: 0 auto;
  }

  .tech-stack-section {
    margin-top: var(--space-12);
    text-align: center;
  }
  .stack-items {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-6);
    justify-content: center;
  }
  .stack-item {
    background-color: var(--card-bg-color);
    border: 1px solid var(--card-border-color);
    padding: var(--space-2) var(--space-5);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .project-header {
      margin: var(--space-4) 0 var(--space-10);
    }
    .subtitle {
      font-size: var(--text-base);
    }
    .launch-button {
      font-size: var(--text-base);
      padding: var(--space-3) var(--space-8);
    }
    .screenshot-container {
      margin-bottom: var(--space-10);
    }
    .tech-stack-section {
      margin-top: var(--space-10);
    }
  }
</style>
