---
import FeatureCard from '@/components/ui/FeatureCard.astro';
import FeatureGrid from '@/components/ui/FeatureGrid.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="HerbReady — ระบบยาสมุนไพรพร้อมจ่าย">
  <div class="project-showcase">
    <header class="project-header">
      <h1>HerbReady</h1>
      <p class="subtitle">
        <span class="title-line">HerbReady - ระบบยาสมุนไพรพร้อมจ่าย</span>
        <span class="desc-line">เปลี่ยน "ความยุ่งยาก" ของการจ่ายยาสมุนไพร ให้กลายเป็น "ความมั่นใจ" ในทุกขั้นตอน</span>
      </p>

      </header>

    <div class="screenshot-container">
      <img
        src="/images/hosxp/herbready.png"
        alt="Screenshot of HerbReady application"
        class="main-screenshot"
      />
    </div>

    <div class="project-details">
      <h2>🔥 ทำไมต้อง HerbReady?</h2>
      <FeatureGrid>
        <FeatureCard title="ช่วยลดความซับซ้อนของเงื่อนไข" icon="clock">
          จัดการเงื่อนไขการเบิกเคลมยาสมุนไพรจาก สปสช. อย่างมีประสิทธิภาพ
        </FeatureCard>
        <FeatureCard title="ลดระยะเวลาในการทำงานของเจ้าหน้าที่" icon="shield-check">
          HerbReady ถูกพัฒนาขึ้นจาก “ปัญหาหน้างานจริง” จึงเน้นการใช้งานที่ง่าย รวดเร็ว และลดภาระงานซ้ำซ้อน
        </FeatureCard>
        <FeatureCard title="เพิ่มโอกาสได้รับเงินชดเชย" icon="users">
          ลดโอกาสข้อมูลผิดพลาด เพราะทุกเคสที่จ่ายยา คือต้นทุนและทรัพยากรของโรงพยาบาล
        </FeatureCard>
        <FeatureCard title="เพิ่มความปลอดภัยให้ผู้ป่วย" icon="beaker">
          ตรวจสอบปฏิกิริยาระหว่างยาสมุนไพรกับยาแผนปัจจุบัน และคัดกรองโรคประจำตัวที่มีข้อห้ามในการใช้ยาสมุนไพร
        </FeatureCard>
      </FeatureGrid>

      <div class="download-section">
        <a
          href="https://github.com/ttmsabotitachiraya/herbready/releases/download/main/HerbReady_2.0.0_x64_en-US.msi"
          target="_blank"
          rel="noopener noreferrer"
          class="cta-button"
        >
          ดาวน์โหลดสำหรับ Windows (.msi)
        </a>
      </div>

      </div>
  </div>
</BaseLayout>

<style>
  .project-header {
    text-align: center;
    margin: var(--space-8) 0 var(--space-8);
  }

  .screenshot-container {
    max-width: 1000px;
    margin: 0 auto var(--space-12);
  }
  .main-screenshot {
    border-radius: var(--radius-lg);
    border: 1px solid var(--card-border-color);
    box-shadow: 0 15px 40px var(--shadow-hover-color);
    width: 100%;
    height: auto;
  }
  .subtitle {
    font-size: var(--text-base);
    margin: var(--space-4) auto var(--space-8);
    max-width: 800px;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .desc-line {
    color: var(--font-color-light);
  }

.project-details {
    max-width: 900px;
    margin: 0 auto;
  }

  .download-section {
    margin-top: var(--space-12);
    text-align: center;
  }

  </style>
