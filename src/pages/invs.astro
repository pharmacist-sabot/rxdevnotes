---
import BlogPostCard from '@/components/blog/BlogPostCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getAllBlogPosts } from '@/lib/blog';

const allPosts = await getAllBlogPosts();
const invsPosts = allPosts
  .filter(post => post.data.category === 'INVS')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="INVS Resources">
  <div class="page-container">
    <h3 class="page-title">INVS</h3>
    <p class="page-subtitle">
      พื้นที่สำหรับรวบรวมเครื่องมือ คู่มือ และบันทึกต่าง ๆ ที่เกี่ยวข้องกับระบบคลังยา INVS
    </p>

    {invsPosts.length > 0
? (
      <div class="post-grid">
        {invsPosts.map(post => (
          <BlogPostCard post={post} />
        ))}
      </div>
    )
: (
      <div class="status-box">
        <p>Coming Soon</p>
      </div>
    )}

    <a href="/blog" class="cta-button">Back to Blog</a>
  </div>
</BaseLayout>

<style>
  .page-container {
    text-align: center;
    padding: 4rem 0;
    max-width: 900px;
    margin: 0 auto;
  }

  .page-title {
    margin-bottom: 0.5rem;
  }

  .page-subtitle {
    font-size: var(--text-base);
    color: var(--font-color-light);
    margin-bottom: var(--space-12);
  }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 420px));
    justify-content: center;
    gap: var(--space-6);
    margin-bottom: var(--space-12);
    text-align: left;
  }

  @media (max-width: 640px) {
    .post-grid {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
  }

  .status-box {
    border: 2px dashed var(--card-border-color);
    border-radius: var(--radius-lg);
    padding: var(--space-12) var(--space-8);
    margin-bottom: var(--space-8);
  }

  .status-box p {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--font-color-light);
    margin: 0;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
</style>
