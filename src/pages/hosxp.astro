---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="HOSxP Resources">
  <div class="container hosxp-container">
    <h1 class="hosxp-title">HOSxP</h1>
    <p class="hosxp-subtitle">
      พื้นที่สำหรับรวบรวมเครื่องมือ คู่มือ และบันทึกต่าง ๆ ที่เกี่ยวข้องกับการพัฒนาโปรแกรม HOSxP
    </p>

    <div class="status-box" role="status" aria-live="polite">
      <p>Coming Soon</p>
    </div>

    <a href="/blog" class="cta-button">Back to Blog</a>
  </div>
</BaseLayout>

<style>
  .hosxp-container {
    text-align: center;
    /* .container provides max-width and centering */
    padding-block: var(--space-12);
  }

  .hosxp-title {
    margin-bottom: var(--space-2);
  }

  .hosxp-subtitle {
    font-size: var(--text-base);
    color: var(--font-color-light);
    margin-bottom: var(--space-8);
  }

  .status-box {
    border: 2px dashed var(--card-border-color);
    border-radius: var(--radius-lg);
    padding: var(--space-12) var(--space-8);
    margin-bottom: var(--space-8);
  }

  .status-box p {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--font-color-light);
    margin: 0;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
</style>
