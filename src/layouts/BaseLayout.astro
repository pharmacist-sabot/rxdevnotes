---
import Navbar from '@/components/layout/Navbar.astro';
import ProgressBar from '@/components/ui/ProgressBar.astro';
import '@/styles/global.css';
import '@/styles/terminal.css';

type Props = {
  title: string;
  description?: string;
};
const {
  title,
  description = 'A developer\'s living knowledge base, curated by a pharmacist turned programmer.',
} = Astro.props;
const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#232748" />
    <title>{`${title} | rxdevman`}</title>
    <!-- Preconnect for faster DNS resolution -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Non-blocking font load: print media trick -->
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Prompt:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=JetBrains+Mono:wght@400;500&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Prompt:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=JetBrains+Mono:wght@400;500&display=swap"
      />
    </noscript>
    <slot name="head" />
  </head>
  <body>
    <ProgressBar />
    <Navbar />
    <main class="main-content">
      <div class="container">
        <slot />
      </div>
    </main>
    <footer class="site-footer">
      <div class="container footer-container">
        <div class="footer-about">
          <h3 class="footer-title"><span class="footer-rx">rx</span><span class="footer-devman">devman</span></h3>
          <p>
            เริ่มต้นจากเภสัชกรรม สู่ความหลงใหลในการพัฒนา
            บันทึกการเดินทางจากวงการสุขภาพสู่โลกเทคโนโลยี
          </p>
        </div>
        <div class="footer-links">
          <h4 class="footer-subtitle">Connect</h4>
          <ul>
            <li>
              <a
                href="https://github.com/pharmacist-sabot/"
                target="_blank"
                rel="noopener noreferrer"
              >GitHub</a>
            </li>
            <li><a href="mailto:pharmacistsabot@gmail.com">Email</a></li>
          </ul>
        </div>
        <div class="footer-bottom">
          <p>&copy; {currentYear} rxdevman. All rights reserved.</p>
        </div>
      </div>
    </footer>
    <style>
      .main-content {
        min-height: calc(100vh - 250px);
        padding: 6rem 0 4rem;
      }
      .site-footer {
        background: var(--card-bg-color);
        border-top: 1px solid var(--card-border-color);
        padding: 4rem 0 2rem;
      }
      .footer-container {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr;
        gap: var(--space-8);
      }
      .footer-title {
        font-family: var(--font-sans);
        font-size: var(--text-lg);
        font-weight: 700;
        letter-spacing: -0.02em;
        margin-bottom: var(--space-2);
      }
      .footer-rx {
        color: var(--brand-color);
      }
      .footer-devman {
        color: var(--font-color);
      }
      .footer-about p {
        color: var(--font-color-light);
        max-width: 400px;
        font-size: var(--text-sm);
      }
      .footer-subtitle {
        font-family: var(--font-sans);
        font-weight: 600;
        color: var(--font-color);
        margin-bottom: var(--space-4);
        font-size: var(--text-base);
      }
      .footer-links ul {
        list-style: none;
        padding: 0;
      }
      .footer-links li {
        margin-bottom: var(--space-3);
      }
      .footer-links a {
        color: var(--font-color-light);
        text-decoration: none;
        font-size: var(--text-sm);
        transition: color 0.2s ease;
      }
      .footer-links a:hover {
        color: var(--brand-color);
      }
      .footer-links a:focus-visible {
        outline: 2px solid var(--brand-color);
        outline-offset: 2px;
        border-radius: var(--radius-sm);
      }
      .footer-bottom {
        grid-column: 1 / -1;
        text-align: center;
        margin-top: var(--space-8);
        padding-top: var(--space-8);
        border-top: 1px solid var(--card-border-color);
        font-size: var(--text-sm);
        color: var(--font-color-light);
      }

      @media (max-width: 768px) {
        .footer-container {
          grid-template-columns: 1fr;
          text-align: center;
        }
        .footer-about p {
          margin-left: auto;
          margin-right: auto;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .footer-links a {
          transition: none;
        }
      }
    </style>
  </body>
</html>
